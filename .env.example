# ==============================================================================
# RideCompare Environment Variables
# Copy this to .env and fill in your values
# ==============================================================================

# Application
APP_NAME=RideCompare API
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change_me_to_a_long_random_string_in_production

# Database
POSTGRES_USER=ridecompare
POSTGRES_PASSWORD=ridecompare_secret
POSTGRES_DB=ridecompare
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Google APIs
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Firebase (push notifications)
FIREBASE_CREDENTIALS_PATH=

# Ride Provider API Keys
# Leave blank to use realistic mock data
UBER_SERVER_TOKEN=
UBER_CLIENT_ID=
OLA_API_KEY=
RAPIDO_API_KEY=
NAMMA_YATRI_API_KEY=

# CORS (comma-separated for production)
BACKEND_CORS_ORIGINS=*

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
COMPARE_RATE_LIMIT_PER_MINUTE=20

# Cache TTLs (seconds)
PROVIDER_CACHE_TTL=30
PLACES_CACHE_TTL=3600
ROUTE_CACHE_TTL=60
